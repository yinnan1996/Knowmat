# KnowMat Backend Configuration
# Copy this file to .env and fill in your values

# LLM API (OpenAI-compatible, e.g., Aliyun DashScope, DeepSeek)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_ID=qwen-plus-latest

# Server
BACKEND_PORT=7896
FRONTEND_ENDPOINT=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PWD=your_db_password
DB_NAME=postgres

# Optional: Models inference endpoint (for material science ML models)
MODELS_ENDPOINT=http://localhost:7893
LOCAL_LLM_ENDPOINT=

# MCP (optional)
MCP_SSE_SERVER_URL=http://localhost:8090/sse
CONTEXT_LENGTH=4096
